{
  "info": {
    "name": "Laravel Study Group API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.authorization && res.authorization.token) {",
                  "    pm.collectionVariables.set('token', res.authorization.token);",
                  "    console.log('Token saved:', res.authorization.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/login",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"john@example.com\",\n    \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.authorization && res.authorization.token) {",
                  "    pm.collectionVariables.set('token', res.authorization.token);",
                  "    console.log('Token saved:', res.authorization.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/logout",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/refresh",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.authorization && res.authorization.token) {",
                  "    pm.collectionVariables.set('token', res.authorization.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/user",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/categories",
              "host": ["{{base_url}}"],
              "path": ["categories"],
              "query": [
                { "key": "search", "value": "", "disabled": true },
                { "key": "include", "value": "products", "disabled": true },
                { "key": "per_page", "value": "10", "disabled": true }
              ]
            },
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Get All Categories (with products)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/categories?include=products",
              "host": ["{{base_url}}"],
              "path": ["categories"],
              "query": [
                { "key": "include", "value": "products" }
              ]
            },
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Get Category by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/categories/1",
              "host": ["{{base_url}}"],
              "path": ["categories", "1"],
              "query": [
                { "key": "include", "value": "products", "disabled": true }
              ]
            },
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/categories",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Elektronik\",\n    \"description\": \"Kategori produk elektronik\"\n}"
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/categories/1",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Elektronik & Gadget\",\n    \"description\": \"Update deskripsi kategori\"\n}"
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/categories/1",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [
                { "key": "search", "value": "", "disabled": true },
                { "key": "include", "value": "category", "disabled": true },
                { "key": "per_page", "value": "10", "disabled": true }
              ]
            },
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Get All Products (with category)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products?include=category",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [
                { "key": "include", "value": "category" }
              ]
            },
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Search Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products?search=laptop&include=category",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [
                { "key": "search", "value": "laptop" },
                { "key": "include", "value": "category" }
              ]
            },
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/products/1",
              "host": ["{{base_url}}"],
              "path": ["products", "1"],
              "query": [
                { "key": "include", "value": "category", "disabled": true }
              ]
            },
            "header": [
              { "key": "Accept", "value": "application/json" }
            ]
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/products",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"Laptop Gaming\",\n    \"description\": \"Laptop untuk gaming high performance\",\n    \"price\": 15000000,\n    \"stock\": 10,\n    \"internal_note\": \"Supplier A - gudang Jakarta\",\n    \"category_id\": 1\n}"
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/products/1",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"price\": 14000000,\n    \"stock\": 8\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/products/1",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ]
          }
        }
      ]
    }
  ]
}
